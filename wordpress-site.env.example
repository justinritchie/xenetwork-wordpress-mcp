# Per-site credentials for xenetwork-wordpress-mcp.
#
# Copy this to ~/.mcp-credentials/wordpress-<site>.env (one per site —
# typically wordpress-root.env and wordpress-ets.env), fill in the real values,
# then run ./setup-site.sh <site>.
#
# WP_APP_PASSWORD comes from WP admin → Users → <your user> → Application
# Passwords. The 24-char value with spaces (e.g. "AAAA BBBB CCCC DDDD EEEE FFFF")
# is correct — paste it literally including the spaces.

# For the root site (https://xenetwork.org):
WP_BASE_URL="https://xenetwork.org"
WP_USERNAME="your-wp-login"
WP_APP_PASSWORD="xxxx xxxx xxxx xxxx xxxx xxxx"
WP_MCP_PORT=8001

# For the ets subsite (uncomment and adjust):
# WP_BASE_URL="https://xenetwork.org/ets"
# WP_USERNAME="your-wp-login"   # often the same — Application Passwords are network-wide
# WP_APP_PASSWORD="xxxx xxxx xxxx xxxx xxxx xxxx"
# WP_MCP_PORT=8002

# Optional — defaults to "wordpress-<site>" if unset:
# WP_MCP_SERVER_NAME="wordpress-root"
