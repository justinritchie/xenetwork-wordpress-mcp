# Credentials for the multi-site Jumbo connector (sites/jumbo/server.py).
#
# Copy to ~/.mcp-credentials/wordpress-jumbo.env, fill in real values,
# chmod 600, then run ./setup-site.sh jumbo.
#
# Unlike wordpress-root.env / wordpress-ets.env (which configure a SINGLE
# WordPress install per file), this file configures N Jumbo client sites
# in one place — one set of WP_SITE_<NAME>_* vars per site. The MCP picks
# WP_DEFAULT_SITE as the active context at boot and exposes a switch_site
# tool to flip between them at runtime.
#
# Each WP_SITE_<NAME>_PASSWORD is an Application Password from that site's
# wp-admin → Users → <your user> → Application Passwords. The 24-char
# value with spaces (e.g. "AAAA BBBB CCCC DDDD EEEE FFFF") is correct —
# paste it literally including the spaces.

# --- MCP server settings -----------------------------------------------------

WP_MCP_PORT=8003
WP_MCP_SERVER_NAME="wordpress-jumbo"

# Which configured site is active at boot. Switchable at runtime via the
# switch_site MCP tool. Must match one of the WP_SITE_<NAME>_* groups below.
WP_DEFAULT_SITE="opusadvisors"

# --- Site: opusadvisors ------------------------------------------------------
# Apex domain for Opus Advisors (currently hosts Gemspring + LCAT events).

WP_SITE_OPUSADVISORS_URL="https://opusadvisors.events"
WP_SITE_OPUSADVISORS_USERNAME="your-wp-login"
WP_SITE_OPUSADVISORS_PASSWORD="xxxx xxxx xxxx xxxx xxxx xxxx"

# --- Site: lcatt -------------------------------------------------------------
# L Catterton subdomain (lcatt.opusadvisors.events).

# WP_SITE_LCATT_URL="https://lcatt.opusadvisors.events"
# WP_SITE_LCATT_USERNAME="your-wp-login"
# WP_SITE_LCATT_PASSWORD="xxxx xxxx xxxx xxxx xxxx xxxx"

# --- Site: jumbo -------------------------------------------------------------
# jumbo.live itself (the platform marketing site).

# WP_SITE_JUMBO_URL="https://jumbo.live"
# WP_SITE_JUMBO_USERNAME="your-wp-login"
# WP_SITE_JUMBO_PASSWORD="xxxx xxxx xxxx xxxx xxxx xxxx"

# --- Adding more sites -------------------------------------------------------
# To add a new client site:
#   1. Pick a short name (lowercase, alphanumeric + underscore)
#   2. Add three env vars: WP_SITE_<NAME>_URL, _USERNAME, _PASSWORD
#   3. Restart the MCP: ./stop.sh jumbo && ./start.sh jumbo
#   4. The new site appears in list_sites() — switch to it with switch_site("<name>")
#
# The MCP scans os.environ at boot for any WP_SITE_*_URL match — no
# code change needed.
